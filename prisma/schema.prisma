generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  password         String?
  phone            String?   @unique
  name             String?
  image            String?
  ridingExperience String?
  bikeTypes        String?
  role             String    @default("RIDER")
  createdGroups    Group[]   @relation("GroupCreator")
  createdRides     Ride[]    @relation("RideCreator")
  memberships      Membership[]
  rsvps            RSVP[]
  messages         Message[]
  notifications    Notification[]
  pushOptIn        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  joinPolicy  String   @default("OPEN") // OPEN, REQUEST_ONLY
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  inviteCode  String?  @unique
  creatorId   String
  creator     User     @relation("GroupCreator", fields: [creatorId], references: [id])
  memberships Membership[]
  rides       Ride[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  role      String   @default("MEMBER") // ADMIN, MEMBER
  status    String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([status])
}

model Ride {
  id                String   @id @default(cuid())
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime?
  meetingPoint      String?
  meetingPointUrl   String?
  destination       String?
  destinationUrl    String?
  itinerary         String?
  terrainDifficulty String   @default("Easy")
  suitableBikes     String?
  riderCap          Int?
  status            String   @default("UPCOMING")
  isPublic          Boolean  @default(true)
  groupId           String
  group             Group    @relation(fields: [groupId], references: [id])
  creatorId         String
  creator           User     @relation("RideCreator", fields: [creatorId], references: [id])
  rsvps             RSVP[]
  messages          Message[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([groupId])
  @@index([creatorId])
  @@index([startTime])
  @@index([isPublic])
  @@index([status])
}

model RSVP {
  id        String   @id @default(cuid())
  status    String   @default("CONFIRMED") // CONFIRMED, INTERESTED, DECLINED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, rideId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([rideId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // GROUP_INVITE, RIDE_UPDATE, JOIN_REQUEST
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  relatedId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
