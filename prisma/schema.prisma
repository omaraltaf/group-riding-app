generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PARTICIPANT
  PLATFORM_ADMIN
}

enum JoinPolicy {
  OPEN
  REQUEST_ONLY
  PUBLIC
  PRIVATE
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  DECLINED
  APPROVED
  INTERESTED
  MAYBE
}

model User {
  id                String         @id @default(cuid())
  email             String?        @unique
  password          String?
  phone             String?        @unique
  name              String?
  image             String?
  role              UserRole       @default(PARTICIPANT)
  vehicleExperience String?
  vehicleTypes      String?
  pushOptIn         Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  memberships       Membership[]
  createdGroups     Group[]        @relation("GroupCreator")
  rsvps             RSVP[]
  messages          Message[]
  createdTrips      Trip[]         @relation("TripCreator")
  notifications     Notification[]
}

model Group {
  id            String         @id @default(cuid())
  name          String
  description   String?
  image         String?
  joinPolicy    JoinPolicy     @default(OPEN)
  inviteCode    String?        @unique
  status        String         @default("PENDING")
  creator       User           @relation("GroupCreator", fields: [creatorId], references: [id])
  creatorId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  trips         Trip[]
}

model Membership {
  id        String   @id @default(cuid())
  role      String   @default("MEMBER")
  status    String   @default("APPROVED")
  userId    String
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([status])
}

model Trip {
  id                String         @id @default(cuid())
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime?
  meetingPoint      String
  meetingPointUrl   String?
  destination       String?
  destinationUrl    String?
  itinerary         String?
  terrainDifficulty String?
  suitableVehicles  String?
  participantCap    Int?
  isPublic          Boolean        @default(true)
  status            String         @default("UPCOMING")
  group             Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId           String
  creator           User           @relation("TripCreator", fields: [creatorId], references: [id])
  creatorId         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  rsvps             RSVP[]
  messages          Message[]

  @@index([groupId])
  @@index([creatorId])
  @@index([startTime])
  @@index([isPublic])
  @@index([status])
}

model RSVP {
  id        String     @id @default(cuid())
  status    RSVPStatus @default(PENDING)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  trip      Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, tripId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  relatedId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
