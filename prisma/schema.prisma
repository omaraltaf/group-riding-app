generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  email            String?        @unique
  password         String?
  phone            String?        @unique
  name             String?
  image            String?
  vehicleExperience String?
  vehicleTypes     String?
  role             String         @default("PARTICIPANT")
  pushOptIn        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdGroups    Group[]        @relation("GroupCreator")
  memberships      Membership[]
  messages         Message[]
  notifications    Notification[]
  rsvps            RSVP[]
  createdRides     Ride[]         @relation("RideCreator")
}

model Group {
  id          String       @id @default(cuid())
  name        String
  description String?
  image       String?
  joinPolicy  String       @default("OPEN")
  inviteCode  String?      @unique
  creatorId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      String       @default("PENDING")
  creator     User         @relation("GroupCreator", fields: [creatorId], references: [id])
  memberships Membership[]
  rides       Ride[]
}

model Membership {
  id        String   @id @default(cuid())
  role      String   @default("MEMBER")
  status    String   @default("APPROVED")
  userId    String
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([status])
}

model Ride {
  id                String    @id @default(cuid())
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime?
  meetingPoint      String?
  meetingPointUrl   String?
  destination       String?
  itinerary         String?
  terrainDifficulty String    @default("Easy")
  suitableVehicles  String?
  participantCap    Int?
  status            String    @default("UPCOMING")
  isPublic          Boolean   @default(true)
  groupId           String
  creatorId         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  destinationUrl    String?
  messages          Message[]
  rsvps             RSVP[]
  creator           User      @relation("RideCreator", fields: [creatorId], references: [id])
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([creatorId])
  @@index([startTime])
  @@index([isPublic])
  @@index([status])
}

model RSVP {
  id        String   @id @default(cuid())
  status    String   @default("CONFIRMED")
  userId    String
  rideId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, rideId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  userId    String
  rideId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([rideId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  relatedId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
